{
  "name": "kitchen-os",
  "version": "1.0.0",
  "description": "Kitchen OS desktop app for Ego Foods",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@vitejs/plugin-react": "^4.3.1",
    "dayjs": "^1.11.13",
    "electron-is-dev": "^3.0.1",
    "howler": "^2.2.4",
    "lucide-react": "^0.468.0",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "vite": "^5.4.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.11.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.egofoods.kitchenos",
    "productName": "Kitchen OS - Ego Foods",
    "files": [
      "dist/**",
      "electron/**",
      "assets/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
